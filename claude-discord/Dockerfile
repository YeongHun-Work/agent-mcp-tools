# ─── Dockerfile ─────────────────────────────────────────────────────────────
# 대상 아키텍처: linux/arm/v7 (Odroid-XU4)
# Node.js 22 slim 이미지를 베이스로 사용
# ─────────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim

# ─── 시스템 패키지 설치 ───────────────────────────────────────────────────────
# better-sqlite3 네이티브 모듈 빌드에 필요한 도구 설치
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    sqlite3 \
  && rm -rf /var/lib/apt/lists/*

# ─── Claude CLI 전역 설치 ─────────────────────────────────────────────────────
RUN npm install -g @anthropic-ai/claude-code

# ─── 작업 디렉토리 설정 ───────────────────────────────────────────────────────
WORKDIR /app

# ─── 의존성 설치 ──────────────────────────────────────────────────────────────
# package*.json 만 먼저 복사해 레이어 캐시를 최대한 활용
COPY package*.json ./

# 프로덕션 의존성만 설치 (devDependencies 제외)
RUN npm install --omit=dev

# ─── 소스 복사 ────────────────────────────────────────────────────────────────
COPY . .

# ─── 데이터 디렉토리 생성 ─────────────────────────────────────────────────────
# SQLite DB, 로그 등 영속 데이터 저장 경로
RUN mkdir -p /app/data && chown node:node /app/data

# ─── 보안: 비루트 사용자로 실행 ──────────────────────────────────────────────
USER node

# ─── 컨테이너 시작 명령 ───────────────────────────────────────────────────────
CMD ["node", "bot.mjs"]
